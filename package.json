{
  "name": "fixral-cms",
  "version": "5.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/cleanup.js",
    "dev": "next dev",
    "prebuild": "node scripts/cleanup.js",
    "build": "next build",
    "prestart": "node scripts/cleanup.js",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "clean": "rimraf .next && rimraf out",
    "format": "prettier --write .",
    "security:check": "npm audit",
    "security:test": "npm audit --audit-level=moderate",
    "perf:check": "next build --profile",
    "perf:analyze": "ANALYZE=true next build",
    "build:analyze": "ANALYZE=true next build",
    "vercel-build": "prisma generate && next build",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "sync-videos": "node scripts/sync-youtube-videos.js",
    "health:check": "curl -f http://localhost:3000/api/health || exit 1",
    "monitoring:dashboard": "open http://localhost:3000/admin/monitoring",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs"
